generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider          = "mysql"
    url               = env("DATABASE_URL")
    shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model user {
    id         String     @id @default(uuid())
    name       String
    role       user_roles
    personId   Int        @unique(map: "usuario_cedula_key")
    password   String
    status     Boolean    @default(true)
    email      String     @default("")
    taxpayer   taxpayer[]
    errors     errors[]   @relation("UserErrors")
    updated_at DateTime   @default(now()) @updatedAt

    groupId String?
    group   FiscalGroup? @relation("GroupMembers", fields: [groupId], references: [id])

    coordinatedGroup    FiscalGroup?          @relation("GroupCoordinator")
    GroupFiscalStat     GroupFiscalStat[]
    GroupFiscalYearStat GroupFiscalYearStat[]
    Census              TaxpayerCensus[]
}

model FiscalGroup {
    id               String             @id @default(uuid())
    name             String             @default("")
    coordinatorId    String             @unique
    coordinator      user               @relation("GroupCoordinator", fields: [coordinatorId], references: [id])
    members          user[]             @relation("GroupMembers")
    created_at       DateTime           @default(now())
    GroupRecordMonth GroupRecordMonth[]
    GroupRecordYear  GroupRecordYear[]
}

model GroupRecordMonth {
    id         String            @id @default(uuid())
    groupId    String
    group      FiscalGroup       @relation(fields: [groupId], references: [id])
    year       Int
    month      Int
    records    GroupFiscalStat[] @relation("MonthToStat")
    created_at DateTime          @default(now())

    @@index([groupId, year, month])
}

model GroupRecordYear {
    id         String      @id @default(uuid())
    groupId    String
    group      FiscalGroup @relation(fields: [groupId], references: [id])
    year       Int
    created_at DateTime    @default(now())

    records GroupFiscalYearStat[] @relation("YearToStat")
}

model GroupFiscalYearStat {
    id                String          @id @default(uuid())
    groupRecordYearId String
    groupRecordYear   GroupRecordYear @relation("YearToStat", fields: [groupRecordYearId], references: [id], onDelete: Cascade)

    fiscalId String
    fiscal   user   @relation(fields: [fiscalId], references: [id])

    process taxpayer_process

    collectedFines Decimal @default(0)
    collectedIVA   Decimal @default(0)
    collectedISLR  Decimal @default(0)
    warnings       Int     @default(0)
    fines          Int     @default(0)
    compromises    Int     @default(0)
    taxpayers      Int     @default(0)

    @@index([groupRecordYearId, fiscalId, process])
}

model GroupFiscalStat {
    id                 String           @id @default(uuid())
    groupRecordMonthId String
    groupRecordMonth   GroupRecordMonth @relation("MonthToStat", fields: [groupRecordMonthId], references: [id], onDelete: Cascade)

    fiscalId String
    fiscal   user   @relation(fields: [fiscalId], references: [id])

    process taxpayer_process

    collectedFines Decimal @default(0)
    collectedIVA   Decimal @default(0)
    collectedISLR  Decimal @default(0)
    warnings       Int     @default(0)
    fines          Int     @default(0)
    compromises    Int     @default(0)
    taxpayers      Int     @default(0)

    @@index([groupRecordMonthId, fiscalId, process])
}

model event {
    id          String     @id @default(uuid())
    date        DateTime   @default(now()) @db.DateTime(0)
    amount      Decimal    @default(0.00) @db.Decimal(20, 2)
    type        event_type
    status      Boolean    @default(true)
    debt        Decimal    @default(0)
    description String     @default("")
    taxpayerId  String
    taxpayer    taxpayer   @relation(fields: [taxpayerId], references: [id], map: "evento_contribuyenteId_fkey", onDelete: Cascade)
    payment     payment[]
    expires_at  DateTime   @default(now())
    updated_at  DateTime   @default(now()) @updatedAt

    // Self-referential relation for linking to a fine event
    fineEventId String? // Link to the parent fine event
    fineEvent   event?  @relation("EventToFine", fields: [fineEventId], references: [id])
    fineEvents  event[] @relation("EventToFine")

    @@index([taxpayerId], map: "evento_contribuyenteId_fkey")
    @@index([fineEventId], map: "evento_fineEventId_fkey") // Index to speed up queries based on fineEventId
    @@index([type], map: "evento_type_idx") // Index for filtering by type (e.g., "FINE")
    @@index([debt], map: "evento_debt_idx") // Index for filtering by debt (e.g., `debt == 0`)
    @@index([date, type], map: "evento_date_type_idx") // Composite index for filtering by both `date` and `type`
}

model payment {
    id         String   @id @default(uuid())
    amount     Decimal  @default(0.00) @db.Decimal(20, 2)
    date       DateTime @default(now()) @db.DateTime(0)
    status     Boolean  @default(true)
    eventId    String
    taxpayerId String
    taxpayer   taxpayer @relation(fields: [taxpayerId], references: [id], map: "pago_contribuyenteId_fkey", onDelete: Cascade)
    event      event    @relation(fields: [eventId], references: [id], map: "pago_eventoId_fkey", onDelete: Cascade)
    updated_at DateTime @default(now()) @updatedAt

    @@index([taxpayerId], map: "pago_contribuyenteId_fkey")
    @@index([date], map: "pago_date_idx") // Index for filtering by `date` ranges
}

model taxpayer {
    id                 String                 @id @default(uuid())
    providenceNum      BigInt
    address            String                 @default("Caracas")
    process            taxpayer_process       @default(NA)
    name               String
    rif                String
    emition_date       DateTime               @default(now())
    contract_type      taxpayer_contract_type @default(ORDINARY)
    status             Boolean                @default(true)
    fase               Taxpayer_Fases         @default(FASE_1)
    notified           Boolean                @default(false)
    culminated         Boolean                @default(false)
    officerId          String?
    event              event[]
    payment            payment[]
    user               user?                  @relation(fields: [officerId], references: [id], map: "contribuyente_funcionarioId_fkey", onDelete: Cascade)
    created_at         DateTime               @default(now())
    updated_at         DateTime               @default(now()) @updatedAt
    investigation_pdfs InvestigationPdf[]
    observations       Observations[]
    IVAReports         IVAReports[]
    ISLRReports        ISLRReports[]
    RepairReports      RepairReport[]

    @@index([officerId], map: "contribuyente_funcionarioId_fkey")
    @@index([process], map: "contribuyente_procedimiento_idx")
    @@index([contract_type], map: "contribuyente_tipoContrato_idx")
}

model IndexIva {
    id            String                 @id @default(uuid())
    contract_type taxpayer_contract_type
    base_amount   Decimal
    created_at    DateTime               @default(now())
    expires_at    DateTime?
    updated_at    DateTime               @default(now()) @updatedAt
}

model TaxpayerCensus {
    id           String                 @id @default(uuid())
    number       Int
    process      taxpayer_process       @default(FP)
    name         String
    rif          String
    type         taxpayer_contract_type @default(ORDINARY)
    address      String                 @default("Caracas")
    emition_date DateTime               @default(now())
    fiscal       user                   @relation(fields: [userId], references: [id])
    userId       String
}

model RepairReport {
    id         String   @id @default(uuid())
    pdf_url    String
    taxpayerId String
    taxpayer   taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
}

model ISLRReports {
    id           String   @id @default(uuid())
    incomes      Decimal
    costs        Decimal
    expent       Decimal
    paid         Decimal  @default(0)
    emition_date DateTime @default(now())
    updatedAt    DateTime @default(now()) @updatedAt
    taxpayerId   String
    taxpayer     taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
}

model IVAReports {
    id         String   @id @default(uuid())
    iva        Decimal?
    purchases  Decimal
    sells      Decimal
    excess     Decimal?
    paid       Decimal  @default(0)
    date       DateTime @default(now())
    taxpayerId String
    taxpayer   taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
    updated_at DateTime @default(now()) @updatedAt
}

model Observations {
    id          String   @id @default(uuid())
    description String
    date        DateTime @default(now())
    taxpayerId  String
    taxpayer    taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
}

model InvestigationPdf {
    id         String   @id @default(uuid())
    pdf_url    String
    taxpayerId String
    taxpayer   taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
}

model errors {
    id          String       @id @default(uuid())
    type        app_error
    title       String       @default("error")
    description String
    status      Boolean      @default(true)
    user        user         @relation("UserErrors", fields: [userId], references: [id], onDelete: Cascade)
    userId      String
    created_at  DateTime     @default(now()) @db.DateTime(0)
    closed_at   DateTime?    @db.DateTime(0)
    updated_at  DateTime     @default(now()) @updatedAt
    errorImages ErrorImage[] // One-to-many relationship with ErrorImage

    @@index([userId])
}

model ErrorImage {
    id      String @id @default(uuid())
    img_src String
    img_alt String
    errorId String
    error   errors @relation(fields: [errorId], references: [id])
}

model GlobalStatistics {
    id        String @id @default(uuid())
    month     String
    year      Int
    collected BigInt

    @@unique([month, year], name: "month_year")
}

enum taxpayer_process {
    FP
    AF
    VDF
    NA
}

enum event_type {
    FINE
    WARNING
    PAYMENT_COMPROMISE
}

enum taxpayer_contract_type {
    SPECIAL
    ORDINARY
}

enum app_error {
    HOME
    TAXPAYER_DETAILS
    TAXPAYERS
    WARNING
    FINES
    PAYMENT
    PAYMENT_COMPROMISE
    STATS
    OTHER
}

enum user_roles {
    FISCAL
    ADMIN
    COORDINATOR
    SUPERVISOR
}

enum Taxpayer_Fases {
    FASE_1
    FASE_2
    FASE_3
    FASE_4
}
