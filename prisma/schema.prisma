generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider          = "mysql"
    url               = env("DATABASE_URL")
    shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model user {
    id       String     @id @default(uuid())
    name     String
    role     String
    personId Int        @unique(map: "usuario_cedula_key")
    password String
    status   Boolean    @default(true)
    taxpayer taxpayer[]
}

model event {
    id         String     @id @default(uuid())
    date       DateTime   @default(now()) @db.DateTime(0)
    amount     Decimal    @default(0.00) @db.Decimal(20, 2)
    type       event_type
    status     Boolean    @default(true)
    debt       Decimal    @default(0)
    taxpayerId String
    taxpayer   taxpayer   @relation(fields: [taxpayerId], references: [id], map: "evento_contribuyenteId_fkey", onDelete: Cascade)
    payment    payment[]
    expires_at DateTime   @default(now())
    
    // Self-referential relation for linking to a fine event
    fineEventId   String?      // Link to the parent fine event
    fineEvent     event?       @relation("EventToFine", fields: [fineEventId], references: [id])
    fineEvents    event[]      @relation("EventToFine")
    
    @@index([taxpayerId], map: "evento_contribuyenteId_fkey")
    @@index([fineEventId], map: "evento_fineEventId_fkey") // Index to speed up queries based on fineEventId
}

model payment {
    id         String   @id @default(uuid())
    amount     Decimal  @default(0.00) @db.Decimal(20, 2)
    date       DateTime @default(now()) @db.DateTime(0)
    status     Boolean  @default(true)
    eventId    String
    taxpayerId String
    taxpayer   taxpayer @relation(fields: [taxpayerId], references: [id], map: "pago_contribuyenteId_fkey")
    event      event    @relation(fields: [eventId], references: [id], map: "pago_eventoId_fkey", onDelete: Cascade)

    @@index([taxpayerId], map: "pago_contribuyenteId_fkey")
}

model taxpayer {
    id            String                 @id @default(uuid())
    providenceNum Int
    process       taxpayer_process       @default(NA)
    name          String
    rif           String                 @db.Char(10) @unique
    contract_type taxpayer_contract_type @default(ORDINARY)
    status        Boolean                @default(true)
    officerId     String?
    event         event[]               
    payment       payment[]
    user          user?                  @relation(fields: [officerId], references: [id], map: "contribuyente_funcionarioId_fkey")

    @@index([officerId], map: "contribuyente_funcionarioId_fkey")
    @@index([process], map: "contribuyente_procedimiento_idx")
    @@index([contract_type], map: "contribuyente_tipoContrato_idx")
}

enum taxpayer_process {
    FP
    AF
    VDF
    NA
}

enum event_type {
    FINE
    WARNING
    PAYMENT_COMPROMISE
}

enum taxpayer_contract_type {
    SPECIAL
    ORDINARY
}
