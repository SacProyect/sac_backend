generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model usuario {
    id             String          @id @default(uuid())
    nombre         String
    tipo           String
    cedula         Int             @unique
    contrasena     String
    contribuyentes contribuyente[]
    status         Boolean         @default(true)
}

model contribuyente {
    id             Int      @id @default(autoincrement())
    nroProvidencia Int
    procedimiento  String   @db.Text
    nombre         String
    rif            String   @db.Char(11)
    tipoContrato   String   @db.Text
    eventos        evento[]
    status         Boolean  @default(true)

    funcionario   usuario? @relation(fields: [funcionarioId], references: [id])
    funcionarioId String?
}

model evento {
    id              BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
    fecha           DateTime       @default(dbgenerated("CURRENT_TIMESTAMP()")) @db.Timestamp()
    monto           Decimal        @default(0) @db.Decimal(20, 2)
    tipo            TipoEvento
    status          Boolean        @default(true)
    contribuyente   contribuyente? @relation(fields: [contribuyenteId], references: [id])
    contribuyenteId Int?
}

enum TipoEvento {
    MULTA
    AVISO
    COMPROMISO_PAGO
    PAGO
}
